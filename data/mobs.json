    "water":     "navy-blue circle, white droplet",
    "wind":      "green circle, white spiral",
    "lightning": "purple/magenta circle, white bolt",
    "ice":       "cyan/light-blue circle, white snowflake",
    "light":     "solid yellow orb",
    "dark":      "solid black orb, grey ring",
    "all":       "rainbow swirl orb (weak/strong to everything)"
  },
  "_weaponLegend": {
    "_provisional": "DORMANT v3 data. Physical damage-type icons captured from the chart but the exact type behind each grey/brown tool is PROVISIONAL — verify during the v3 weapon pass before surfacing in UI.",
    "piercing": "thin grey metal dagger",
    "slashing": "grey angular blade/axe-hammer head on a handle",
    "blunt":    "brown wooden club/mace",
    "h2h":      "fist (not distinctly observed on the chart)"
  },

